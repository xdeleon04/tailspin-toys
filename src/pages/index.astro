---
import Layout from '../layouts/Layout.astro';
import GameCard from '../components/GameCard.astro';
import PageHero from '../components/PageHero.astro';
import EmptyState from '../components/EmptyState.astro';
import { getDatabase } from '../lib/db';
import { defaultGameSortOption, gameSortChoices, getAllGames } from '../lib/games';

export const prerender = true;

const games = await getAllGames(getDatabase());
---

<Layout title="Tailspin Toys - Crowdfunding your new favorite game!">
  <div class="py-8">
    <PageHero
      title="Welcome to Tailspin Toys"
      subtitle="Find your next game! And maybe even back one! Explore our collection!"
    />

    <div>
      <div class="mb-6 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div>
          <h2 class="text-2xl font-medium text-slate-100">Featured Games</h2>
          <p id="game-sort-help" class="mt-2 max-w-2xl text-sm text-slate-400">
            Games without ratings appear after rated games when sorting by star rating.
          </p>
        </div>

        <div class="w-full space-y-4 md:w-[34rem]">
          <form data-testid="game-search-form">
            <label for="game-search" class="mb-2 block text-sm font-medium text-slate-200">
              Search games by title
            </label>
            <input
              id="game-search"
              type="search"
              placeholder="Type to filter titles..."
              class="w-full rounded-lg border border-slate-600 bg-slate-900 px-4 py-3 text-sm text-slate-100 shadow-sm transition-colors duration-200 placeholder:text-slate-400 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500"
              aria-describedby="game-search-help"
              data-testid="game-search-input"
            />
            <p id="game-search-help" class="mt-2 text-sm text-slate-400">
              Filtering updates as you type. Press Enter to submit the same search from the keyboard.
            </p>
          </form>

          <div>
            <label for="game-sort" class="mb-2 block text-sm font-medium text-slate-200">
              Sort games
            </label>
            <select
              id="game-sort"
              class="w-full rounded-lg border border-slate-600 bg-slate-900 px-4 py-3 text-sm text-slate-100 shadow-sm transition-colors duration-200 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500"
              aria-describedby="game-sort-help"
              data-testid="game-sort-select"
            >
              {gameSortChoices.map((choice) => (
                <option value={choice.value} selected={choice.value === defaultGameSortOption}>
                  {choice.label}
                </option>
              ))}
            </select>
          </div>
        </div>
      </div>

      {games.length === 0 ? (
        <EmptyState text="No games available at the moment." />
      ) : (
        <>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" data-testid="games-grid">
            {games.map((game) => <GameCard game={game} />)}
          </div>
          <div data-testid="game-search-empty-state" hidden>
            <EmptyState>
              <p class="text-slate-300" role="status" aria-live="polite">
                No games match your search.
              </p>
            </EmptyState>
          </div>
        </>
      )}
    </div>
  </div>
</Layout>

<script>
  function initGameCatalogControls(): void {
    const sortSelect = document.querySelector<HTMLSelectElement>('[data-testid="game-sort-select"]');
    const searchForm = document.querySelector<HTMLFormElement>('[data-testid="game-search-form"]');
    const searchInput = document.querySelector<HTMLInputElement>('[data-testid="game-search-input"]');
    const gamesGrid = document.querySelector<HTMLElement>('[data-testid="games-grid"]');
    const searchEmptyState = document.querySelector<HTMLElement>('[data-testid="game-search-empty-state"]');

    if (!sortSelect || !searchForm || !searchInput || !gamesGrid || !searchEmptyState) {
      console.warn('Game catalog controls are missing expected homepage elements.');
      return;
    }

    const allCards = Array.from(gamesGrid.querySelectorAll<HTMLElement>('[data-testid="game-card"]'));
    const getTitle = (card: HTMLElement): string => card.dataset.gameTitle ?? '';
    const normalizeSearchTerm = (value: string): string => value.trim().toLocaleLowerCase('en');
    const getRating = (card: HTMLElement): number | null => {
      const rawRating = card.dataset.gameRating;

      if (!rawRating) {
        return null;
      }

      const rating = Number(rawRating);
      return Number.isFinite(rating) ? rating : null;
    };
    const compareTitleAsc = (a: HTMLElement, b: HTMLElement): number =>
      getTitle(a).localeCompare(getTitle(b), 'en', { sensitivity: 'base' });
    const compareTitleDesc = (a: HTMLElement, b: HTMLElement): number => compareTitleAsc(b, a);
    const compareRatingDesc = (a: HTMLElement, b: HTMLElement): number => {
      const ratingA = getRating(a);
      const ratingB = getRating(b);

      if (ratingA === null && ratingB === null) {
        return compareTitleAsc(a, b);
      }

      if (ratingA === null) {
        return 1;
      }

      if (ratingB === null) {
        return -1;
      }

      const ratingOrder = ratingB - ratingA;
      return ratingOrder === 0 ? compareTitleAsc(a, b) : ratingOrder;
    };

    const renderCatalog = (): void => {
      const sortOption = sortSelect.value;
      const query = normalizeSearchTerm(searchInput.value);
      const sortedCards = [...allCards];

      switch (sortOption) {
        case 'title-desc':
          sortedCards.sort(compareTitleDesc);
          break;
        case 'rating-desc':
          sortedCards.sort(compareRatingDesc);
          break;
        case 'title-asc':
          sortedCards.sort(compareTitleAsc);
          break;
        default:
          console.warn(`Unsupported game sort option: ${sortOption}`);
          return;
      }

      gamesGrid.append(...sortedCards);

      let visibleCards = 0;

      for (const card of sortedCards) {
        const matchesSearch = query.length === 0 || normalizeSearchTerm(getTitle(card)).includes(query);
        card.hidden = !matchesSearch;

        if (matchesSearch) {
          visibleCards += 1;
        }
      }

      const hasMatches = visibleCards > 0;
      gamesGrid.hidden = !hasMatches;
      searchEmptyState.hidden = hasMatches;
    };

    sortSelect.addEventListener('change', () => {
      renderCatalog();
    });

    searchInput.addEventListener('input', () => {
      renderCatalog();
    });

    searchForm.addEventListener('submit', (event) => {
      event.preventDefault();
      renderCatalog();
    });

    renderCatalog();
  }

  initGameCatalogControls();
</script>
